# LLM Provider: glm | deepseek
APP_LLM_PROVIDER=glm

# 智谱 GLM API Key (https://open.bigmodel.cn/)
APP_GLM_API_KEY=your-glm-api-key-here

# DeepSeek API Key (https://platform.deepseek.com/)
APP_DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 可选: 覆盖默认模型配置
# APP_LLM_MODEL=glm-4-flash
# APP_LLM_TIMEOUT=60
# APP_LLM_TEMPERATURE=0.1

# 调试模式
APP_DEBUG=true
